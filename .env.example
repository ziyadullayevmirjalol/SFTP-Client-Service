# ── Auth (REQUIRED — nothing in the app works without a valid session) ──
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me
# Session signing key. Generate one: openssl rand -base64 32
AUTH_SECRET=replace-with-a-long-random-secret

# ── Storage connection (single connection for now) ──
STORAGE_PROVIDER=vercel-blob
# Shown in the header
STORAGE_LABEL=Vercel Blob
# Vercel Blob read-write token (Project → Storage → Blob)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxx
